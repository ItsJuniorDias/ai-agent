{
  "expo": {
    "name": "AI Agent",
    "slug": "agent-gemini",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "agentgemini",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.alexandrejunior.agentgemini",
      "infoPlist": {
        "NSPhotoLibraryAddUsageDescription": "Permite salvar na sua galeria as imagens geradas pelo agente."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F7F8FC",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,
      "package": "com.alexandrejunior.agentgemini"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "splash": null,
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon_nobg.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F7F8FC"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "O aplicativo precisa de permissão para ler sua galeria.",
          "savePhotosPermission": "O aplicativo precisa de permissão para salvar as imagens geradas por IA na sua galeria de fotos."
        }
      ],
      [
        "@react-native-voice/voice",
        {
          "microphonePermission": "Permitir que o assistente ouça seus comandos de voz.",
          "speechRecognitionPermission": "Permitir que o assistente transforme sua fala em texto."
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#5364E8"
        }
      ],
      "expo-background-task"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
