{
  "expo": {
    "name": "AI Agent",
    "slug": "agent-gemini",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "agentgemini",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.agentgemini",
      "infoPlist": {
        "NSPhotoLibraryAddUsageDescription": "This app needs permission to save generated story images to your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.agentgemini"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "splash": null,
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "O aplicativo precisa de permissão para ler sua galeria.",
          "savePhotosPermission": "O aplicativo precisa de permissão para salvar as imagens geradas por IA na sua galeria de fotos."
        }
      ],
      [
        "@react-native-voice/voice",
        {
          "microphonePermission": "Permitir que o assistente ouça seus comandos de voz.",
          "speechRecognitionPermission": "Permitir que o assistente transforme sua fala em texto."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
